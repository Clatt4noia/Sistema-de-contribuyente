# ============================================================================
# CONFIGURACIÓN DEL CERTIFICADO DIGITAL PARA SUNAT
# ============================================================================
#
# Recomendación:
# - Usa una ruta ABSOLUTA fuera del repo (por ejemplo: C:/certs/sunat/certificado.pfx)
# - Alternativa local (sin commitear): coloca el archivo en storage/app/secure/
#   y referencia la ruta absoluta a ese archivo.
#
# Luego ejecuta:
#   php artisan config:clear
#
# ============================================================================

# Ruta absoluta al certificado digital (.pfx o .pem)
BILLING_CERTIFICATE_PATH=C:/certs/sunat/certificado.pfx

# Contraseña del certificado (si no tiene, dejar vacío: "")
BILLING_CERTIFICATE_PASSPHRASE=""

