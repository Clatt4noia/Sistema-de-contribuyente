# ============================================================================
# CONFIGURACIÓN DEL CERTIFICADO DIGITAL PARA SUNAT
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copia estas líneas
# 2. Pégalas en tu archivo .env (en la raíz del proyecto)
# 3. Reemplaza "TU_CONTRASEÑA_AQUI" con la contraseña real del certificado
#    (Si no tiene contraseña, deja las comillas vacías: "")
# 4. Guarda el archivo .env
# 5. Ejecuta: php artisan config:clear
# 6. Ejecuta: php verify_certificate.php
#
# ============================================================================

# Ruta absoluta al certificado digital (.pfx)
BILLING_CERTIFICATE_PATH=C:/Users/User/Desktop/practicas_preprofesionales/laravel12-auth/laravel-livewire/app/billing/certificado.pfx

# Contraseña del certificado (si no tiene contraseña, dejar vacío: "")
BILLING_CERTIFICATE_PASSPHRASE="TU_CONTRASEÑA_AQUI"

# ============================================================================
# NOTAS IMPORTANTES:
# ============================================================================
# - Usa barras diagonales / (NO barras invertidas \)
# - La ruta debe ser ABSOLUTA (ruta completa desde C:/)
# - Si la contraseña tiene espacios o caracteres especiales, mantenla entre comillas
# - Después de modificar .env, SIEMPRE ejecuta: php artisan config:clear
# ============================================================================
